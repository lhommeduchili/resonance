{
  "name": "resonance",
  "version": "0.1.0",
  "license": "GPL-3.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"pnpm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "pnpm run build && electron-builder && codesign --force --deep --sign - dist/mac-arm64/resonance.app"
  },
  "build": {
    "appId": "com.resonance.app",
    "productName": "resonance",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Resonance requires microphone access to broadcast live audio streams.",
        "NSCameraUsageDescription": "Resonance does not use the camera."
      }
    }
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "node-datachannel": "^0.32.1",
    "nostr-tools": "^2.23.3",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "28.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "4.0.18",
    "wait-on": "^9.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-datachannel",
      "esbuild",
      "electron",
      "electron-builder",
      "electron-winstaller"
    ]
  }
}